{
  "name": "landscape-ui",
  "private": true,
  "version": "26.10.0.1081",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run lint && pnpm run tcm:run && tsc && vite build",
    "build:e2e": "pnpm run build --mode e2e",
    "lint": "eslint --fix src e2e",
    "preview": "vite preview",
    "test": "pnpm exec playwright test",
    "test:saas": "VITE_SELF_HOSTED_ENV=false pnpm exec playwright test --project=saas",
    "test:self-hosted": "VITE_SELF_HOSTED_ENV=true pnpm exec playwright test --project=self-hosted",
    "test:ui": "pnpm exec playwright test --ui",
    "vitest": "vitest",
    "coverage": "vitest run --coverage",
    "coverage-report": "tsx src/tests/aggregate-coverage.ts",
    "coverage:full": "pnpm run coverage && pnpm run coverage-report",
    "test:codegen": "pnpm exec playwright codegen",
    "test:report": "pnpm exec playwright show-report",
    "tcm:run": "tcm \"src/**\" --pattern *.module.scss",
    "tcm:watch": "pnpm tcm:run --watch"
  },
  "dependencies": {
    "@canonical/landscape-openapi": "0.0.70",
    "@canonical/react-components": "4.6.0",
    "@monaco-editor/react": "4.7.0",
    "@sentry/react": "10.56.0",
    "@tanstack/react-query": "5.101.0",
    "axios": "1.18.0",
    "classnames": "2.5.1",
    "downshift": "9.3.4",
    "formik": "2.4.9",
    "moment": "2.30.1",
    "monaco-editor": "0.55.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.16.0",
    "usehooks-ts": "3.1.1",
    "vanilla-framework": "4.51.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.4",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/react-table": "7.7.20",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "msw": "2.4.11",
    "prettier": "3.8.3",
    "sass": "1.100.0",
    "sass-embedded": "1.100.0",
    "stylelint": "17.12.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1",
    "tsx": "4.23.1",
    "typed-css-modules": "0.9.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "yaml": "2.9.0"
  }
}
